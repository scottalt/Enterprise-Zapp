<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Enterprise-Zapp Report — {{ tenant_name }}</title>
<style>
  /* ── Reset & Base ────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg:       #0f1117;
    --surface:  #1a1d27;
    --surface2: #222534;
    --border:   #2e3347;
    --text:     #e2e8f0;
    --muted:    #9ba3b5;
    --accent:   #38bdf8;
    --critical: #ef4444;
    --high:     #f97316;
    --medium:   #eab308;
    --low:      #22c55e;
    --clean:    #10b981;
    --brand:    #818cf8;
    --ca-accent: #a78bfa;
    --nav-height: 49px;
  }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    line-height: 1.6;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── Layout ──────────────────────────────────────────────────────────── */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .section { margin-bottom: 40px; scroll-margin-top: calc(var(--nav-height) + 8px); }

  /* ── Header ──────────────────────────────────────────────────────────── */
  .header {
    background: linear-gradient(135deg, #1a1d27 0%, #0f1117 100%);
    border-bottom: 1px solid var(--border);
    padding: 32px 0 24px;
    margin-bottom: 40px;
  }
  .header-inner { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
  .brand { display: flex; align-items: center; gap: 12px; }
  .brand-logo {
    font-size: 28px; font-weight: 800; letter-spacing: -1px;
    background: linear-gradient(135deg, var(--brand), var(--accent));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .brand-tagline { color: var(--muted); font-size: 13px; margin-top: 2px; }
  .brand-subtitle { color: var(--muted); font-size: 11px; margin-top: 1px; opacity: 0.7; }
  .header-meta { text-align: right; font-size: 13px; color: var(--muted); }
  .header-meta strong { color: var(--text); }
  .readonly-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3);
    color: var(--clean); border-radius: 20px; padding: 3px 12px; font-size: 12px; font-weight: 600;
    margin-top: 8px;
  }

  /* ── Section headings ────────────────────────────────────────────────── */
  .section-title {
    font-size: 18px; font-weight: 700; color: var(--text);
    border-left: 3px solid var(--brand); padding-left: 12px;
    margin-bottom: 16px;
  }
  .section-subtitle { color: var(--muted); font-size: 13px; margin-top: 4px; }

  /* ── Summary cards ───────────────────────────────────────────────────── */
  .summary-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px;
    margin-bottom: 32px;
  }
  .summary-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
    padding: 20px; text-align: center; position: relative; overflow: hidden;
  }
  .summary-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--card-color, var(--brand));
  }
  .summary-card .count { font-size: 36px; font-weight: 800; color: var(--card-color, var(--text)); line-height: 1; }
  .summary-card .label { font-size: 12px; color: var(--muted); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.05em; }
  .card-critical { --card-color: var(--critical); }
  .card-high     { --card-color: var(--high); }
  .card-medium   { --card-color: var(--medium); }
  .card-low      { --card-color: var(--low); }
  .card-clean    { --card-color: var(--clean); }
  .card-total    { --card-color: var(--brand); }

  /* ── Risk badges ─────────────────────────────────────────────────────── */
  .badge {
    display: inline-flex; align-items: center; gap: 4px;
    border-radius: 20px; padding: 2px 10px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .badge-critical { background: rgba(239,68,68,0.15); color: var(--critical); border: 1px solid rgba(239,68,68,0.3); }
  .badge-high     { background: rgba(249,115,22,0.15); color: var(--high);     border: 1px solid rgba(249,115,22,0.3); }
  .badge-medium   { background: rgba(234,179,8,0.15);  color: var(--medium);   border: 1px solid rgba(234,179,8,0.3); }
  .badge-low      { background: rgba(34,197,94,0.15);  color: var(--low);      border: 1px solid rgba(34,197,94,0.3); }
  .badge-clean    { background: rgba(16,185,129,0.15); color: var(--clean);    border: 1px solid rgba(16,185,129,0.3); }

  /* ── Score bar ───────────────────────────────────────────────────────── */
  .score-bar-wrap { display: flex; align-items: center; gap: 8px; }
  .score-bar { height: 6px; border-radius: 3px; background: var(--border); flex: 1; overflow: hidden; }
  .score-bar-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
  .score-num { font-size: 12px; font-weight: 700; min-width: 28px; text-align: right; }

  /* ── Tables ──────────────────────────────────────────────────────────── */
  /*
   * Each table lives inside a scrollable .table-wrap container.
   * thead th sticks to top:0 of that container — completely independent
   * of the page sticky-nav, so no nav-height coordination needed.
   */
  .table-wrap {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--border);
  }
  table { width: 100%; border-collapse: collapse; }
  thead th {
    background: var(--surface2); color: var(--muted);
    font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;
    padding: 10px 14px; text-align: left; white-space: nowrap;
    position: sticky; top: 0; z-index: 2;
    cursor: pointer; user-select: none;
  }
  thead th:hover { color: var(--text); }
  thead th::after { content: ' ⇅'; opacity: 0.4; }
  thead th.asc::after  { content: ' ↑'; opacity: 1; }
  thead th.desc::after { content: ' ↓'; opacity: 1; }
  tbody tr { border-top: 1px solid var(--border); transition: background 0.1s; }
  tbody tr:hover { background: var(--surface2); }
  tbody td { padding: 10px 14px; font-size: 13px; vertical-align: middle; }
  .app-name { font-weight: 600; color: var(--text); }
  .app-id   { font-size: 11px; color: var(--muted); font-family: monospace; }
  .app-desc { font-size: 11px; color: var(--text-secondary, #9ca3af); margin-top: 3px; max-width: 340px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .app-desc-label { font-weight: 600; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.03em; margin-right: 4px; }
  .app-meta-block { margin-top: 10px; padding: 8px 12px; background: var(--surface); border-radius: 6px; border: 1px solid var(--border); font-size: 12px; color: var(--text); }
  .app-meta-block .meta-label { font-weight: 600; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.03em; display: block; margin-bottom: 2px; }
  .app-meta-block .meta-value { white-space: pre-wrap; word-break: break-word; }

  /* ── Expandable rows ─────────────────────────────────────────────────── */
  .expand-row { display: none; background: var(--surface2); }
  .expand-row.open { display: table-row; }
  .expand-content { padding: 16px 14px; }
  .expand-trigger { cursor: pointer; }
  .expand-trigger > td:first-child:not(.cb-col) { position: relative; padding-left: 26px; }
  .expand-trigger > td:first-child:not(.cb-col)::before {
    content: '▶';
    position: absolute; left: 8px; top: 50%; transform: translateY(-50%);
    font-size: 10px; color: var(--muted);
  }
  .expand-trigger.open > td:first-child:not(.cb-col)::before { content: '▼'; }
  /* Chevron for rows with a checkbox column (inventory table) */
  .expand-trigger > td.cb-col + td { position: relative; padding-left: 26px; }
  .expand-trigger > td.cb-col + td::before {
    content: '▶';
    position: absolute; left: 8px; top: 50%; transform: translateY(-50%);
    font-size: 10px; color: var(--muted);
  }
  .expand-trigger.open > td.cb-col + td::before { content: '▼'; }

  /* ── Signal chips ────────────────────────────────────────────────────── */
  .signals { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px; }
  .signal-chip {
    display: inline-flex; align-items: center; gap: 5px;
    border-radius: 6px; padding: 4px 10px; font-size: 11px; font-weight: 500;
  }
  .signal-critical { background: rgba(239,68,68,0.1);  color: #fca5a5; border: 1px solid rgba(239,68,68,0.2); }
  .signal-high     { background: rgba(249,115,22,0.1); color: #fdba74; border: 1px solid rgba(249,115,22,0.2); }
  .signal-medium   { background: rgba(234,179,8,0.1);  color: #fde047; border: 1px solid rgba(234,179,8,0.2); }
  .signal-low      { background: rgba(34,197,94,0.1);  color: #86efac; border: 1px solid rgba(34,197,94,0.2); }

  /* ── Signal count badge ─────────────────────────────────────────────── */
  .signal-count-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 24px; height: 24px; border-radius: 12px;
    font-size: 11px; font-weight: 700; padding: 0 7px;
    cursor: default;
  }
  .signal-count-badge.signal-critical { background: rgba(239,68,68,0.15); color: var(--critical); border: 1px solid rgba(239,68,68,0.3); }
  .signal-count-badge.signal-high     { background: rgba(249,115,22,0.15); color: var(--high);     border: 1px solid rgba(249,115,22,0.3); }
  .signal-count-badge.signal-medium   { background: rgba(234,179,8,0.15);  color: var(--medium);   border: 1px solid rgba(234,179,8,0.3); }
  .signal-count-badge.signal-low      { background: rgba(34,197,94,0.15);  color: var(--low);      border: 1px solid rgba(34,197,94,0.3); }

  /* ── Pagination controls ──────────────────────────────────────────── */
  .pagination-bar {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 12px; margin-top: 10px; font-size: 13px; color: var(--muted);
  }
  .pagination-bar select {
    background: var(--surface); border: 1px solid var(--border); color: var(--text);
    border-radius: 6px; padding: 4px 8px; font-size: 12px; cursor: pointer; outline: none;
  }
  .pagination-pages { display: flex; gap: 4px; align-items: center; }
  .pagination-pages button {
    background: var(--surface); border: 1px solid var(--border); color: var(--muted);
    border-radius: 6px; padding: 4px 10px; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: background 0.15s, color 0.15s;
  }
  .pagination-pages button:hover:not(:disabled) { color: var(--text); border-color: var(--muted); }
  .pagination-pages button.active { background: rgba(56,189,248,0.15); border-color: var(--accent); color: var(--accent); }
  .pagination-pages button:disabled { opacity: 0.35; cursor: default; }

  /* ── Entra admin portal deep-link ───────────────────────────────────── */
  .entra-link {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.75rem;
    margin-left: 4px;
    opacity: 0.6;
  }
  .entra-link:hover { opacity: 1; }

  /* ── Recommendation box ──────────────────────────────────────────────── */
  .rec-box {
    background: rgba(56,189,248,0.05); border: 1px solid rgba(56,189,248,0.2);
    border-radius: 8px; padding: 12px 14px; margin-top: 12px; font-size: 13px; color: #7dd3fc;
  }
  .rec-box strong { color: var(--accent); }

  /* ── Search/filter bar ───────────────────────────────────────────────── */
  .filter-bar { display: flex; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
  .filter-bar input {
    background: var(--surface); border: 1px solid var(--border); color: var(--text);
    border-radius: 8px; padding: 8px 14px; font-size: 13px; width: 260px; outline: none;
  }
  .filter-bar input:focus { border-color: var(--accent); }
  .filter-bar select {
    background: var(--surface); border: 1px solid var(--border); color: var(--text);
    border-radius: 8px; padding: 8px 14px; font-size: 13px; outline: none; cursor: pointer;
  }

  /* ── Risk band filter buttons ────────────────────────────────────────── */
  .band-filters { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-bottom: 10px; }
  .band-btn {
    border: 1px solid var(--border); background: var(--surface); color: var(--muted);
    border-radius: 20px; padding: 4px 14px; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: background 0.15s, color 0.15s, border-color 0.15s;
    user-select: none;
  }
  .band-btn:hover { color: var(--text); border-color: var(--muted); }
  .band-btn.active-all  { background: rgba(129,140,248,0.18); border-color: var(--brand); color: var(--brand); }
  .band-btn.active-critical { background: rgba(239,68,68,0.15); border-color: var(--critical); color: var(--critical); }
  .band-btn.active-high     { background: rgba(249,115,22,0.15); border-color: var(--high); color: var(--high); }
  .band-btn.active-medium   { background: rgba(234,179,8,0.15); border-color: var(--medium); color: var(--medium); }
  .band-btn.active-low      { background: rgba(34,197,94,0.15); border-color: var(--low); color: var(--low); }
  .band-btn.active-clean    { background: rgba(16,185,129,0.15); border-color: var(--clean); color: var(--clean); }

  /* ── Microsoft toggle button ─────────────────────────────────────────── */
  .ms-toggle-btn {
    border: 1px solid var(--border); background: var(--surface); color: var(--muted);
    border-radius: 20px; padding: 4px 14px; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: background 0.15s, color 0.15s, border-color 0.15s;
    user-select: none;
  }
  .ms-toggle-btn:hover { color: var(--text); border-color: var(--muted); }
  .ms-toggle-btn.hiding {
    background: rgba(56,189,248,0.1); border-color: var(--accent); color: var(--accent);
  }

  /* ── Top recommendations ─────────────────────────────────────────────── */
  .rec-list { list-style: none; }
  .rec-list li {
    display: flex; align-items: flex-start; gap: 12px;
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
    padding: 14px 16px; margin-bottom: 10px;
  }
  .rec-num { font-size: 18px; font-weight: 800; color: var(--brand); min-width: 28px; }
  .rec-text { font-size: 14px; color: var(--text); }
  .rec-sub  { font-size: 12px; color: var(--muted); margin-top: 2px; }

  /* ── Methodology ─────────────────────────────────────────────────────── */
  .methodology-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; }
  .method-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 16px; }
  .method-card h4 { font-size: 13px; font-weight: 700; color: var(--accent); margin-bottom: 8px; }
  .method-card p  { font-size: 12px; color: var(--muted); }
  .perm-list { list-style: none; margin-top: 8px; }
  .perm-list li { font-size: 12px; color: var(--muted); padding: 2px 0; }
  .perm-list li::before { content: '• '; color: var(--clean); }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  .footer {
    border-top: 1px solid var(--border); padding: 24px 0; margin-top: 48px;
    text-align: center; color: var(--muted); font-size: 12px;
  }

  /* ── Skipped notice ──────────────────────────────────────────────────── */
  .notice {
    background: rgba(234,179,8,0.08); border: 1px solid rgba(234,179,8,0.25);
    border-radius: 8px; padding: 12px 16px; font-size: 13px; color: #fde047; margin-bottom: 24px;
  }
  .notice strong { color: #fbbf24; }

  /* ── Callout banners ─────────────────────────────────────────────────── */
  .callout {
    border-radius: 8px; padding: 14px 18px; font-size: 13px; margin-bottom: 20px;
    display: flex; align-items: flex-start; gap: 12px;
  }
  .callout-icon { font-size: 18px; line-height: 1.4; flex-shrink: 0; }
  .callout-body { flex: 1; }
  .callout-body strong { display: block; margin-bottom: 4px; font-size: 14px; }
  .callout-info {
    background: rgba(56,189,248,0.07); border: 1px solid rgba(56,189,248,0.25); color: #7dd3fc;
  }
  .callout-info strong { color: var(--accent); }
  .callout-muted {
    background: rgba(129,140,248,0.07); border: 1px solid rgba(129,140,248,0.2); color: #a5b4fc;
  }
  .callout-muted strong { color: var(--brand); }
  .callout-warning {
    background: rgba(234,179,8,0.08); border: 1px solid rgba(234,179,8,0.3); color: #fde047;
  }
  .callout-warning strong { color: #fbbf24; }
  .artifact-name-badge {
    display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap;
    background: rgba(234,179,8,0.15); border: 1px solid rgba(234,179,8,0.4);
    border-radius: 6px; padding: 7px 12px; margin: 6px 0 10px 0;
    font-weight: 600; font-size: 14px; color: #fbbf24;
  }
  .artifact-app-id { font-family: monospace; font-size: 11px; opacity: 0.65; font-weight: 400; }

  /* ── Conditional Access section ─────────────────────────────────────── */
  .ca-section-title {
    font-size: 18px; font-weight: 700; color: var(--text);
    border-left: 3px solid var(--ca-accent); padding-left: 12px;
    margin-bottom: 16px;
  }
  .ca-summary-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px;
    margin-bottom: 28px;
  }
  .ca-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
    padding: 18px; text-align: center; position: relative; overflow: hidden;
  }
  .ca-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--ca-accent);
  }
  .ca-card .count { font-size: 32px; font-weight: 800; color: var(--ca-accent); line-height: 1; }
  .ca-card .label { font-size: 12px; color: var(--muted); margin-top: 6px; text-transform: uppercase; letter-spacing: 0.05em; }
  .ca-card.ca-covered .count { color: var(--clean); }
  .ca-card.ca-covered::before { background: var(--clean); }
  .ca-card.ca-uncovered .count { color: var(--medium); }
  .ca-card.ca-uncovered::before { background: var(--medium); }
  .ca-badge-covered   { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(34,197,94,0.12); color: var(--clean); border: 1px solid rgba(34,197,94,0.3); }
  .ca-badge-uncovered { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(234,179,8,0.12); color: var(--medium); border: 1px solid rgba(234,179,8,0.3); }
  .ca-state-enabled  { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; background: rgba(34,197,94,0.12); color: var(--clean); }
  .ca-state-disabled { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; background: rgba(142,142,142,0.12); color: var(--muted); }
  .ca-state-report   { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; background: rgba(56,189,248,0.12); color: var(--accent); }
  .ca-policy-names   { font-size: 11px; color: var(--muted); font-style: italic; max-width: 280px; }
  .ca-unavailable {
    background: rgba(167,139,250,0.07); border: 1px solid rgba(167,139,250,0.25);
    border-radius: 10px; padding: 28px 24px; text-align: center;
  }
  .ca-unavailable h3 { color: var(--ca-accent); margin-bottom: 10px; }
  .ca-unavailable p  { color: var(--muted); font-size: 13px; max-width: 520px; margin: 0 auto; }
  .ca-unavailable code { color: var(--ca-accent); background: rgba(167,139,250,0.1); border-radius: 4px; padding: 1px 6px; }

  /* ── Sticky nav ──────────────────────────────────────────────────────── */
  .sticky-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15,17,23,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    padding: 8px 0;
  }
  .sticky-nav ul {
    display: flex;
    gap: 4px;
    list-style: none;
    overflow-x: auto;
    padding: 0 24px;
    max-width: 1200px;
    margin: 0 auto;
    white-space: nowrap;
    scrollbar-width: none;
  }
  .sticky-nav ul::-webkit-scrollbar { display: none; }
  .sticky-nav a {
    display: block;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }
  .sticky-nav a:hover { color: var(--text); background: var(--surface2); text-decoration: none; }
  .sticky-nav a.active { color: var(--accent); background: rgba(56,189,248,0.1); }

  /* ── Signal detail text (print-visible) ─────────────────────────────── */
  .signal-detail-text {
    font-size: 12px;
    color: var(--muted);
    margin-top: 6px;
    line-height: 1.5;
    white-space: pre-wrap;
  }
  .signin-breakdown { margin-top: 10px; padding: 8px 12px; background: var(--surface); border-radius: 6px; border: 1px solid var(--border); }
  .signin-breakdown .si-label { font-weight: 600; color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: 0.03em; display: block; margin-bottom: 6px; }
  .signin-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 4px 16px; font-size: 12px; }
  .signin-grid .si-type { color: var(--muted); }
  .signin-grid .si-none { color: var(--muted); font-style: italic; }
  .signal-block {
    margin-bottom: 12px;
    padding: 10px 12px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    border-left: 3px solid var(--border);
    border-radius: 4px;
    background: rgba(255,255,255,0.015);
  }
  .signal-block:last-child { border-bottom: none; margin-bottom: 0; }
  .signal-block.sev-critical { border-left-color: var(--critical); background: rgba(239,68,68,0.04); }
  .signal-block.sev-high     { border-left-color: var(--high);     background: rgba(249,115,22,0.04); }
  .signal-block.sev-medium   { border-left-color: var(--medium);   background: rgba(234,179,8,0.04); }
  .signal-block.sev-low      { border-left-color: var(--low);      background: rgba(34,197,94,0.04); }
  .signal-rec-text {
    font-size: 12px;
    color: #7dd3fc;
    margin-top: 5px;
    line-height: 1.5;
    font-weight: 500;
  }
  .doc-link {
    display: inline-block; margin-left: 8px;
    font-size: 11px; color: var(--accent); opacity: 0.75;
    text-decoration: none; border-bottom: 1px dashed var(--accent);
  }
  .doc-link:hover { opacity: 1; }

  /* ── Muted empty-state cell ──────────────────────────────────────────── */
  td.muted { color: var(--muted); font-style: italic; text-align: center; padding: 20px 14px; }

  /* ── Row selection checkbox ──────────────────────────────────────────── */
  .row-select-cb {
    width: 16px; height: 16px; cursor: pointer; accent-color: var(--accent);
    margin: 0; vertical-align: middle;
  }
  thead th.cb-col, tbody td.cb-col {
    width: 32px; min-width: 32px; max-width: 32px;
    text-align: center; padding: 10px 6px;
  }
  thead th.cb-col { cursor: default; }
  thead th.cb-col::after { content: ''; }

  /* ── Export toolbar ────────────────────────────────────────────────── */
  .export-toolbar {
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .export-btn {
    border: 1px solid var(--accent); background: rgba(56,189,248,0.1); color: var(--accent);
    border-radius: 8px; padding: 6px 16px; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: background 0.15s, color 0.15s;
    user-select: none;
  }
  .export-btn:hover { background: rgba(56,189,248,0.25); }
  .export-btn:disabled { opacity: 0.4; cursor: default; }
  .export-btn:disabled:hover { background: rgba(56,189,248,0.1); }
  .select-count { font-size: 12px; color: var(--muted); }

  /* ── Section-specific colored headers ────────────────────────────────── */
  #sec-critical .section-title { border-left-color: var(--critical); }
  #sec-stale    .section-title { border-left-color: var(--high); }
  #sec-creds    .section-title { border-left-color: var(--medium); }
  #sec-orphaned .section-title { border-left-color: var(--high); }
  #sec-priv     .section-title { border-left-color: var(--critical); }
  #sec-owners   .section-title { border-left-color: var(--brand); }

  /* ── Section count badge ───────────────────────────────────────────── */
  .section-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 26px; height: 22px; border-radius: 11px;
    font-size: 12px; font-weight: 700; padding: 0 8px;
    margin-left: 10px; vertical-align: middle;
  }
  #sec-critical .section-count { background: rgba(239,68,68,0.15); color: var(--critical); }
  #sec-stale    .section-count { background: rgba(249,115,22,0.15); color: var(--high); }
  #sec-creds    .section-count { background: rgba(234,179,8,0.15);  color: var(--medium); }
  #sec-orphaned .section-count { background: rgba(249,115,22,0.15); color: var(--high); }
  #sec-priv     .section-count { background: rgba(239,68,68,0.15); color: var(--critical); }

  /* ── Section urgency banner ────────────────────────────────────────── */
  .section-banner {
    border-radius: 8px; padding: 12px 16px; font-size: 13px;
    margin-bottom: 16px; display: flex; align-items: center; gap: 10px;
  }
  .section-banner-icon { font-size: 16px; flex-shrink: 0; }
  .section-banner-critical {
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.25); color: #fca5a5;
  }
  .section-banner-warning {
    background: rgba(249,115,22,0.08); border: 1px solid rgba(249,115,22,0.25); color: #fdba74;
  }
  .section-banner-info {
    background: rgba(234,179,8,0.08); border: 1px solid rgba(234,179,8,0.25); color: #fde047;
  }

  /* ── Owner view ──────────────────────────────────────────────────── */
  .owner-group {
    background: var(--surface); border: 1px solid var(--border); border-radius: 10px;
    margin-bottom: 12px; overflow: hidden;
  }
  .owner-group-header {
    display: flex; align-items: center; gap: 12px; padding: 12px 16px;
    cursor: pointer; user-select: none; transition: background 0.15s;
  }
  .owner-group-header:hover { background: rgba(255,255,255,0.03); }
  .owner-group-chevron {
    font-size: 12px; color: var(--muted); transition: transform 0.2s; flex-shrink: 0;
  }
  .owner-group.open .owner-group-chevron { transform: rotate(90deg); }
  .owner-group-name { font-weight: 600; font-size: 14px; }
  .owner-group-upn { font-size: 12px; color: var(--muted); }
  .owner-group-disabled { color: var(--critical); font-size: 11px; font-weight: 600; }
  .owner-group-stats {
    margin-left: auto; display: flex; align-items: center; gap: 12px; font-size: 12px; color: var(--muted);
  }
  .owner-group-body { display: none; border-top: 1px solid var(--border); }
  .owner-group.open .owner-group-body { display: block; }
  .owner-app-row {
    display: flex; align-items: center; gap: 12px; padding: 8px 16px 8px 40px;
    border-bottom: 1px solid rgba(255,255,255,0.04); font-size: 13px;
  }
  .owner-app-row:last-child { border-bottom: none; }
  .owner-app-name { flex: 1; min-width: 0; }
  .owner-app-name a { color: var(--text); }
  .owner-app-name a:hover { color: var(--accent); }
  .owner-app-score { width: 50px; text-align: right; font-weight: 700; }
  .owner-app-band { width: 70px; text-align: center; }
  .owner-app-signals { flex: 0 0 auto; display: flex; gap: 4px; flex-wrap: wrap; max-width: 300px; }

  /* ── Row striping for sub-sections ─────────────────────────────────── */
  #tbl-critical tbody tr.expand-trigger:nth-of-type(4n+1),
  #tbl-stale tbody tr.expand-trigger:nth-of-type(4n+1),
  #tbl-creds tbody tr.expand-trigger:nth-of-type(4n+1),
  #tbl-orphaned tbody tr.expand-trigger:nth-of-type(4n+1),
  #tbl-priv tbody tr.expand-trigger:nth-of-type(4n+1) {
    background: rgba(255,255,255,0.04);
  }

  /* ── Expand-all / collapse-all toggle button ───────────────────────── */
  .expand-all-btn {
    border: 1px solid var(--border); background: var(--surface); color: var(--muted);
    border-radius: 6px; padding: 4px 12px; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: background 0.15s, color 0.15s;
    user-select: none; margin-left: auto;
  }
  .expand-all-btn:hover { color: var(--text); border-color: var(--muted); }

  /* ── Sub-section search bar ──────────────────────────────────────────── */
  .sub-filter-bar { display: flex; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; align-items: center; }
  .sub-filter-bar input {
    background: var(--surface); border: 1px solid var(--border); color: var(--text);
    border-radius: 8px; padding: 7px 12px; font-size: 13px; width: 240px; outline: none;
  }
  .sub-filter-bar input:focus { border-color: var(--accent); }
  .sub-filter-bar .sub-count { font-size: 12px; color: var(--muted); }

  /* ── Signal preview chips (inline in collapsed rows) ───────────────── */
  .signal-previews { display: inline-flex; gap: 4px; flex-wrap: wrap; vertical-align: middle; }
  .signal-preview-chip {
    display: inline-block; border-radius: 4px; padding: 1px 6px;
    font-size: 10px; font-weight: 600; white-space: nowrap;
  }
  .signal-preview-chip.spc-critical { background: rgba(239,68,68,0.15); color: #fca5a5; }
  .signal-preview-chip.spc-high     { background: rgba(249,115,22,0.15); color: #fdba74; }
  .signal-preview-chip.spc-medium   { background: rgba(234,179,8,0.15);  color: #fde047; }
  .signal-preview-chip.spc-low      { background: rgba(34,197,94,0.15);  color: #86efac; }
  .signal-more { font-size: 10px; color: var(--muted); font-weight: 600; padding: 1px 4px; }

  /* ── Copy app ID button ────────────────────────────────────────────── */
  .copy-id-btn {
    display: inline-block; border: none; background: none; color: var(--muted);
    font-size: 11px; cursor: pointer; padding: 0 4px; vertical-align: middle;
    opacity: 0.5; transition: opacity 0.15s, color 0.15s;
  }
  .copy-id-btn:hover { opacity: 1; color: var(--accent); }
  .copy-id-btn.copied { color: var(--clean); opacity: 1; }

  /* ── Review status badge ───────────────────────────────────────────── */
  .review-status {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 18px; height: 18px; border-radius: 9px;
    font-size: 9px; font-weight: 700; cursor: pointer;
    border: 1.5px solid var(--border); background: transparent;
    color: var(--muted); transition: all 0.15s; vertical-align: middle;
    margin-right: 6px; user-select: none; padding: 0;
  }
  .review-status:hover { border-color: var(--accent); color: var(--accent); }
  .review-status[data-status="reviewed"] { border-color: var(--clean); background: rgba(16,185,129,0.15); color: var(--clean); }
  .review-status[data-status="flagged"] { border-color: var(--high); background: rgba(249,115,22,0.15); color: var(--high); }
  .review-status[data-status="remediated"] { border-color: var(--accent); background: rgba(56,189,248,0.15); color: var(--accent); }

  /* ── Review progress bar ───────────────────────────────────────────── */
  .progress-bar-wrap {
    display: flex; align-items: center; gap: 10px; margin-bottom: 12px; font-size: 12px; color: var(--muted);
  }
  .progress-track {
    flex: 1; max-width: 200px; height: 6px; border-radius: 3px; background: var(--border); overflow: hidden;
  }
  .progress-fill { height: 100%; border-radius: 3px; background: var(--clean); transition: width 0.3s; }

  /* ── Export All button ─────────────────────────────────────────────── */
  .export-all-btn {
    border: 1px solid var(--border); background: var(--surface); color: var(--muted);
    border-radius: 8px; padding: 6px 14px; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: background 0.15s, color 0.15s;
  }
  .export-all-btn:hover { color: var(--text); border-color: var(--muted); }

  /* ── Back-to-top button ────────────────────────────────────────────── */
  .back-to-top {
    position: fixed; bottom: 28px; right: 28px; z-index: 200;
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--surface); border: 1px solid var(--border);
    color: var(--muted); font-size: 18px; cursor: pointer;
    display: none; align-items: center; justify-content: center;
    transition: background 0.15s, color 0.15s, opacity 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .back-to-top:hover { background: var(--surface2); color: var(--accent); border-color: var(--accent); }
  .back-to-top.visible { display: flex; }

  /* ── Keyboard shortcut modal ───────────────────────────────────────── */
  .kbd-modal-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300;
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); display: none;
    align-items: center; justify-content: center;
  }
  .kbd-modal-overlay.open { display: flex; }
  .kbd-modal {
    background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
    padding: 24px 28px; max-width: 420px; width: 90%;
  }
  .kbd-modal h3 { font-size: 16px; font-weight: 700; margin-bottom: 16px; color: var(--text); }
  .kbd-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
  .kbd-row:last-child { border-bottom: none; }
  .kbd-key {
    display: inline-block; background: var(--surface2); border: 1px solid var(--border);
    border-radius: 4px; padding: 2px 8px; font-size: 12px; font-weight: 600;
    font-family: monospace; color: var(--accent); min-width: 28px; text-align: center;
  }
  .kbd-desc { font-size: 13px; color: var(--muted); }

  /* ── Print styles ────────────────────────────────────────────────────── */
  @media print {
    .sticky-nav { display: none; }
    body { background: white; color: black; }
    .header { background: white; border-bottom: 2px solid #e2e8f0; }
    .brand-logo { -webkit-text-fill-color: #4f46e5; }
    .surface, .surface2 { background: #f8fafc; }
    .filter-bar { display: none; }
    .export-toolbar { display: none; }
    .cb-col { display: none; }
    .sub-filter-bar { display: none; }
    .back-to-top { display: none !important; }
    .kbd-modal-overlay { display: none !important; }
    .review-status { display: none; }
    .copy-id-btn { display: none; }
    .progress-bar-wrap { display: none; }
  }
</style>
</head>
<body>

{# ── Reusable macro: app name / app ID / description cell ──────────────────── #}
{# ── Reusable macro: signal preview chips (top 3 inline) ────────────────────── #}
{% macro signal_previews(app) %}
<div class="signal-previews">
  {% for sig in app.signals[:3] %}<span class="signal-preview-chip spc-{{ sig.severity }}">{{ sig.title }}</span>{% endfor %}{% if app.signals | length > 3 %}<span class="signal-more">+{{ app.signals | length - 3 }}</span>{% endif %}
</div>
{% endmacro %}

{# ── Reusable macro: app name / app ID / description cell ──────────────────── #}
{% macro app_cell(app) %}
<div class="app-name"><button class="review-status" data-appid="{{ app.app_id | lower }}" data-status="unreviewed" onclick="event.stopPropagation(); cycleReviewStatus(this)" title="Click to mark review status">&#9675;</button>{{ app.display_name }}<a href="https://entra.microsoft.com/#view/Microsoft_AAD_RegisteredApps/ApplicationMenuBlade/~/Overview/appId/{{ app.app_id }}" target="_blank" rel="noopener" title="Open in Entra admin center" class="entra-link">↗</a></div>
<div class="app-id">{{ app.app_id }}<button class="copy-id-btn" onclick="event.stopPropagation(); copyAppId(this, '{{ app.app_id }}')" title="Copy app ID">&#9112;</button></div>
{% set _notes = (app.notes or '') | trim %}
{% set _desc = (app.description or '') | trim %}
{% set _display = _notes or _desc %}
{% if _display %}
<div class="app-desc" title="{{ _display }}"><span class="app-desc-label">{{ 'Notes' if _notes else 'Desc' }}:</span>{{ _display[:120] }}{{ '…' if _display | length > 120 else '' }}</div>
{% endif %}
{% endmacro %}

{# ── Reusable macro: notes/description block for expand rows ─────────────── #}
{% macro app_meta_block(app) %}
{% set _notes = (app.notes or '') | trim %}
{% set _desc = (app.description or '') | trim %}
{% if _notes or _desc %}
<div class="app-meta-block">
  {% if _notes %}<div><span class="meta-label">Notes</span><span class="meta-value">{{ _notes }}</span></div>{% endif %}
  {% if _desc %}<div{% if _notes %} style="margin-top:6px;"{% endif %}><span class="meta-label">Description</span><span class="meta-value">{{ _desc }}</span></div>{% endif %}
</div>
{% endif %}
{% endmacro %}

{# ── Reusable macro: sign-in activity breakdown ───────────────────────────── #}
{% macro signin_breakdown(app) %}
<div class="signin-breakdown">
  <span class="si-label">Sign-in Activity Breakdown{% if app.is_saml_app %} <span style="display:inline-block;background:rgba(56,189,248,0.15);color:var(--accent);font-size:9px;padding:1px 6px;border-radius:3px;vertical-align:middle;margin-left:6px;font-weight:700;letter-spacing:0.05em;">SAML</span>{% endif %}</span>
  {% if not app.sign_in_data_available %}
  <div style="font-size:12px; color:var(--muted); font-style:italic;">
    {%- if app.is_saml_app -%}
    SAML app — the servicePrincipalSignInActivities endpoint may not capture SAML sign-ins. Check Entra ID sign-in logs directly.
    {%- else -%}
    No sign-in data returned by Graph API for this app.
    {%- endif -%}
  </div>
  {% else %}
  <div class="signin-grid">
    {% set si_types = [
      ("Interactive", app.last_interactive_sign_in),
      ("Non-interactive", app.last_non_interactive_sign_in),
      ("Delegated (client)", app.last_delegated_client_sign_in),
      ("Delegated (resource)", app.last_delegated_resource_sign_in),
      ("App-only (client)", app.last_app_auth_client_sign_in),
      ("App-only (resource)", app.last_app_auth_resource_sign_in),
    ] %}
    {% for label, val in si_types %}
    <div><span class="si-type">{{ label }}:</span> {% if val %}<span style="font-weight:600;">{{ val | format_date }}</span>{% else %}<span class="si-none">none</span>{% endif %}</div>
    {% endfor %}
  </div>
  {% endif %}
</div>
{% endmacro %}

<!-- ── Header ────────────────────────────────────────────────────────────── -->
<div class="header">
  <div class="container">
    <div class="header-inner">
      <div class="brand">
        <div>
          <div class="brand-logo">Enterprise-Zapp</div>
          <div class="brand-tagline">Zap the stale. Secure the rest.</div>
          <div class="brand-subtitle">Entra ID Enterprise App Hygiene Scanner</div>
        </div>
      </div>
      <div class="header-meta">
        <div><strong>Tenant:</strong> {{ tenant_name }}</div>
        <div><strong>Tenant ID:</strong> {{ tenant_id }}</div>
        <div><strong>Scan date:</strong> {{ collected_at }}</div>
        <div><strong>Tool version:</strong> {{ version }}</div>
        <div><span class="readonly-badge">&#10003; Read-Only Scan — No changes made</span></div>
      </div>
    </div>
  </div>
</div>

<!-- ── Sticky nav ────────────────────────────────────────────────────────── -->
<nav class="sticky-nav" id="sticky-nav">
  <ul>
    <li><a href="#sec-summary">Summary</a></li>
    <li><a href="#sec-inventory">Inventory</a></li>
    {% if critical_high_apps %}<li><a href="#sec-critical">Critical &amp; High</a></li>{% endif %}
    {% if stale_apps %}<li><a href="#sec-stale">Stale</a></li>{% endif %}
    {% if credential_apps %}<li><a href="#sec-creds">Credentials</a></li>{% endif %}
    {% if orphaned_apps %}<li><a href="#sec-orphaned">Orphaned</a></li>{% endif %}
    {% if high_privilege_apps %}<li><a href="#sec-priv">Over-Privileged</a></li>{% endif %}
    <li><a href="#sec-ca">CA Coverage</a></li>
    {% if owner_groups %}<li><a href="#sec-owners">By Owner</a></li>{% endif %}
    <li><a href="#sec-methodology">Methodology</a></li>
    <li style="margin-left: auto;"><a href="#" onclick="event.preventDefault(); document.getElementById('kbd-modal').classList.add('open')" title="Keyboard shortcuts" style="opacity: 0.5; font-size: 11px;">? Shortcuts</a></li>
  </ul>
</nav>

<div class="container">

  <!-- ── Skipped data notice ────────────────────────────────────────────── -->
  {% if skipped %}
  <div class="notice">
    <strong>Note:</strong> Some data could not be collected due to permission gaps.
    {% if 'sign_in_activities' in skipped %}
    Sign-in activity data was unavailable — staleness signals may be incomplete.
    Ensure <code>Reports.Read.All</code> is granted and admin-consented.
    {% endif %}
  </div>
  {% endif %}

  <!-- ── Executive Summary ──────────────────────────────────────────────── -->
  <div class="section" id="sec-summary">
    <div class="section-title">
      Executive Summary
      <div class="section-subtitle">{{ total_apps }} enterprise apps scanned</div>
    </div>

    <div class="summary-grid">
      <div class="summary-card card-total">
        <div class="count">{{ total_apps }}</div>
        <div class="label">Total Apps</div>
      </div>
      <div class="summary-card card-critical">
        <div class="count">{{ band_counts.critical }}</div>
        <div class="label">Critical Risk</div>
      </div>
      <div class="summary-card card-high">
        <div class="count">{{ band_counts.high }}</div>
        <div class="label">High Risk</div>
      </div>
      <div class="summary-card card-medium">
        <div class="count">{{ band_counts.medium }}</div>
        <div class="label">Medium Risk</div>
      </div>
      <div class="summary-card card-low">
        <div class="count">{{ band_counts.low }}</div>
        <div class="label">Low Risk</div>
      </div>
      <div class="summary-card card-clean">
        <div class="count">{{ band_counts.clean }}</div>
        <div class="label">Clean</div>
      </div>
    </div>

    <!-- ── Tool artifact cleanup reminder ───────────────────────────────── -->
    {% if tool_artifact_apps %}
    <div class="callout callout-warning">
      <div class="callout-icon">&#9888;</div>
      <div class="callout-body">
        <strong>Cleanup Reminder</strong>
        {% for app in tool_artifact_apps %}
        <div class="artifact-name-badge">
          {{ app.display_name }}<span class="artifact-app-id">{{ app.app_id }}</span>
        </div>
        {% endfor %}
        This app registration was created by Enterprise-Zapp's setup.ps1 script. Delete it after your audit to avoid leaving unused credentials in your tenant.
        <div style="margin-top: 8px;">Run: <code>.\setup.ps1 -Cleanup</code> &nbsp;·&nbsp; or re-run the scan with <code>--cleanup-after</code></div>
        <div style="margin-top: 6px;"><small style="opacity:0.75;">Cleanup requires the <strong>Application Administrator</strong> or <strong>Global Administrator</strong> role — different from the Privileged Role Administrator role used during setup.</small></div>
      </div>
    </div>
    {% endif %}

    <!-- ── Microsoft first-party apps banner ────────────────────────────── -->
    {% if hide_microsoft and microsoft_app_count > 0 %}
    <div class="callout callout-muted">
      <div class="callout-icon">&#8505;</div>
      <div class="callout-body">
        <strong>{{ microsoft_app_count }} Microsoft first-party app{{ 's' if microsoft_app_count != 1 else '' }} excluded from this report</strong>
        These are built-in Microsoft services (Teams, SharePoint, Azure AD, etc.) and are expected in your tenant.
        To include them, re-run without the <code>--hide-microsoft</code> flag.
      </div>
    </div>
    {% elif not hide_microsoft and microsoft_app_count > 0 %}
    <div class="callout callout-info">
      <div class="callout-icon">&#8505;</div>
      <div class="callout-body">
