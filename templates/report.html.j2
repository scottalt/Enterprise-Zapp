  <!-- ── Conditional Access Coverage ──────────────────────────────────── -->
  <div class="section" id="sec-ca">
    <div class="ca-section-title">
      Conditional Access Coverage
      <div class="section-subtitle">Which enterprise apps are protected by enforced CA policies?</div>
    </div>

    {% if not ca_available %}
    <div class="ca-unavailable">
      {% if ca_permission_granted is sameas false %}
      <h3>&#128274; Permission Not Granted — Coverage Unknown</h3>
      <p>
        The <code>Policy.Read.All</code> permission was not granted, so Conditional Access policy data could not be retrieved.
        CA coverage for this tenant is <strong>unknown</strong> — this does not mean no policies exist.<br><br>
        Re-run <code>.\setup.ps1</code> (it now includes this permission automatically) to enable CA coverage analysis.
        Note: Conditional Access requires <strong>Azure AD Premium P1</strong> or higher.
      </p>
      {% else %}
      <h3>&#128274; CA Data Unavailable</h3>
      <p>
        Conditional Access policy data could not be retrieved — the endpoint may be unreachable or this cache predates CA support.<br><br>
        Run a fresh scan to populate this section.
        Note: Conditional Access requires <strong>Azure AD Premium P1</strong> or higher.
      </p>
      {% endif %}
    </div>

    {% else %}

    <!-- Summary cards -->
    <div class="ca-summary-grid">
      <div class="ca-card">
        <div class="count">{{ ca_policy_summaries | length }}</div>
        <div class="label">Total Policies</div>
      </div>
      <div class="ca-card">
        <div class="count">{{ ca_policy_summaries | selectattr('is_enforced') | list | length }}</div>
        <div class="label">Enforced</div>
      </div>
      <div class="ca-card ca-covered">
        <div class="count">{{ ca_coverage_pct }}%</div>
        <div class="label">Apps Covered</div>
      </div>
      <div class="ca-card ca-covered">
        <div class="count">{{ ca_covered_count }}</div>
        <div class="label">Covered Apps</div>
      </div>
      <div class="ca-card ca-uncovered">
        <div class="count">{{ ca_app_coverages | length - ca_covered_count }}</div>
        <div class="label">Not Covered</div>
      </div>
    </div>

    {% if not ca_policy_summaries %}
    <div class="callout callout-info" style="margin-bottom:20px;">
      <div class="callout-icon">&#8505;</div>
      <div class="callout-body">
        <strong>No Conditional Access policies found</strong>
        The <code>Policy.Read.All</code> permission was granted successfully but this tenant has no CA policies configured.
        Consider creating policies in the <a href="https://entra.microsoft.com/#view/Microsoft_AAD_ConditionalAccess/CaOverviewBlade" target="_blank" rel="noopener">Entra admin center</a>.
      </div>
    </div>
    {% elif ca_policy_summaries | selectattr('is_enforced') | list | length == 0 %}
    <div class="callout callout-warning" style="margin-bottom:20px;">
      <div class="callout-icon">&#9888;</div>
      <div class="callout-body">
        <strong>No enforced CA policies found</strong>
        All {{ ca_policy_summaries | length }} {{ 'policy is' if ca_policy_summaries | length == 1 else 'policies are' }} either disabled or in report-only mode. No enterprise apps are protected.
      </div>
    </div>
    {% endif %}

    <!-- App coverage table -->
    <div class="section-title" style="font-size:15px; margin-bottom:12px; border-color: var(--ca-accent);">App Coverage</div>
    <div class="table-wrap" style="margin-bottom:28px; max-height: 500px; overflow-y: auto;">
      <table id="tbl-ca-apps">
        <thead>
          <tr>
            <th onclick="sortTable('tbl-ca-apps',0)">App Name</th>
            <th onclick="sortTable('tbl-ca-apps',1)">App ID</th>
            <th onclick="sortTable('tbl-ca-apps',2)">Coverage</th>
            <th onclick="sortTable('tbl-ca-apps',3)">Enforced Policies</th>
          </tr>
        </thead>
        <tbody>
          {% if ca_app_coverages %}
          {% for cov in ca_app_coverages | sort(attribute='display_name') %}
          <tr>
            <td class="app-name">{{ cov.display_name }}</td>
            <td class="app-id">{{ cov.app_id }}</td>
            <td>
              {% if cov.is_covered %}
              <span class="ca-badge-covered">Covered</span>
              {% else %}
              <span class="ca-badge-uncovered">Not Covered</span>
              {% endif %}
            </td>
            <td class="ca-policy-names">
              {% if cov.policy_names %}
              {{ cov.policy_names | join(', ') }}
              {% else %}
              <span style="color:var(--muted);">—</span>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
          {% else %}
          <tr><td colspan="4" class="muted">No app coverage data available.</td></tr>
          {% endif %}
        </tbody>
      </table>
    </div>

    <!-- Policy inventory table -->
    <div class="section-title" style="font-size:15px; margin-bottom:12px; border-color: var(--ca-accent);">Policy Inventory</div>
    <div class="table-wrap" style="max-height: 400px; overflow-y: auto;">
      <table id="tbl-ca-policies">
        <thead>
          <tr>
            <th onclick="sortTable('tbl-ca-policies',0)">Policy Name</th>
            <th onclick="sortTable('tbl-ca-policies',1)">State</th>
            <th onclick="sortTable('tbl-ca-policies',2)">App Scope</th>
            <th onclick="sortTable('tbl-ca-policies',3)">Created</th>
            <th onclick="sortTable('tbl-ca-policies',4)">Last Modified</th>
          </tr>
        </thead>
        <tbody>
          {% for pol in ca_policy_summaries | sort(attribute='display_name') %}
          <tr>
            <td class="app-name">{{ pol.display_name }}</td>
            <td><span class="{{ pol.state_css }}">{{ pol.state_label }}</span></td>
            <td>
              {% if pol.includes_all_apps %}
                All apps
                {% if pol.excluded_app_ids %}
                  <span style="color:var(--muted); font-size:11px;">({{ pol.excluded_app_ids | length }} excluded)</span>
                {% endif %}
              {% elif pol.included_app_ids %}
                {{ pol.included_app_ids | length }} specific app{{ 's' if pol.included_app_ids | length != 1 else '' }}
              {% else %}
                <span style="color:var(--muted);">None</span>
              {% endif %}
            </td>
            <td style="white-space:nowrap;">{{ pol.created_datetime | format_date }}</td>
            <td style="white-space:nowrap;">{{ pol.modified_datetime | format_date }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% endif %}{# ca_available #}
  </div>

  <!-- ── By Owner ──────────────────────────────────────────────────────── -->
  {% if owner_groups %}
  <div class="section" id="sec-owners">
    <div class="section-title">
      Apps by Owner<span class="section-count">{{ owner_groups | length }}</span>
      <div class="section-subtitle">Apps grouped by assigned owner — click an owner to expand their apps</div>
    </div>
    <div class="sub-filter-bar">
      <input type="text" id="owner-search" placeholder="Search by owner name, UPN, or app name..." oninput="filterOwnerGroups(this.value)">
      <span class="sub-count" id="owner-match-count"></span>
    </div>
    <div id="owner-groups-container">
      {% for group in owner_groups %}
      <div class="owner-group" data-owner-name="{{ group.owner_name | lower }}" data-owner-upn="{{ group.owner_upn | lower }}" data-app-names="{{ group.apps | map(attribute='display_name') | join('|') | lower }}">
        <div class="owner-group-header" onclick="toggleOwnerGroup(this.parentElement)">
          <span class="owner-group-chevron">&#9654;</span>
          <span class="owner-group-name">{{ group.owner_name }}</span>
          {% if group.owner_upn %}<span class="owner-group-upn">({{ group.owner_upn }})</span>{% endif %}
          {% if not group.owner_enabled %}<span class="owner-group-disabled">DISABLED</span>{% endif %}
          <div class="owner-group-stats">
            <span>{{ group.app_count }} app{{ 's' if group.app_count != 1 else '' }}</span>
            <span class="badge badge-{{ group.max_risk_band }}" style="font-size: 10px;">{{ group.max_risk_band }}</span>
          </div>
        </div>
        <div class="owner-group-body">
          {% for app in group.apps %}
          <div class="owner-app-row">
            <div class="owner-app-name">
              <a href="https://entra.microsoft.com/#view/Microsoft_AAD_RegisteredApps/ApplicationMenuBlade/~/Overview/appId/{{ app.app_id }}" target="_blank" rel="noopener" title="Open in Entra admin center">{{ app.display_name }}</a>
              <span style="font-size:11px; color:var(--muted); margin-left:6px;">{{ app.app_id }}</span>
            </div>
            <div class="owner-app-score" style="color: var(--{{ app.risk_band }})">{{ app.risk_score }}</div>
            <div class="owner-app-band"><span class="badge badge-{{ app.risk_band }}" style="font-size:10px;">{{ app.risk_band }}</span></div>
            <div class="owner-app-signals">
              {% for sig in app.signals[:3] %}<span class="signal-preview-chip spc-{{ sig.severity }}" style="font-size:10px;">{{ sig.title }}</span>{% endfor %}
              {% if app.signals | length > 3 %}<span class="signal-more">+{{ app.signals | length - 3 }}</span>{% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- ── Methodology ────────────────────────────────────────────────────── -->
  <div class="section" id="sec-methodology">
    <div class="section-title">Methodology &amp; Transparency</div>
    <div class="methodology-grid">
      <div class="method-card">
        <h4>Data Collected</h4>
        <ul class="perm-list">
          <li>All service principals (enterprise apps)</li>
          <li>User &amp; group assignments per app</li>
          <li>App owners per app</li>
          <li>OAuth2 delegated permission grants</li>
          <li>Application permission assignments</li>
          <li>Service principal sign-in activity</li>
          <li>Disabled user list (for orphan detection)</li>
          <li>Conditional Access policies (if permitted)</li>
        </ul>
      </div>
      <div class="method-card">
        <h4>Permissions Used</h4>
        <ul class="perm-list">
          <li>Application.Read.All</li>
          <li>Directory.Read.All</li>
          <li>AuditLog.Read.All</li>
          <li>Reports.Read.All</li>
          <li>Policy.Read.All</li>
        </ul>
      </div>
      <div class="method-card">
        <h4>Risk Scoring</h4>
        <p>Risk scores (0–100) combine weighted hygiene signals: staleness (+30), never signed in (+35), no owners (+20), expired credentials (+25), high-privilege + stale (+25), and more. Scores cap at 100.</p>
      </div>
      <div class="method-card">
        <h4>Staleness Threshold</h4>
