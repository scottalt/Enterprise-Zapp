                  <span class="signal-chip signal-{{ sig.severity }}">{{ sig.title }}</span>
                  {% if sig.detail %}<p class="signal-detail-text">{{ sig.detail }}</p>{% endif %}
                  {% if sig.recommendation %}<p class="signal-rec-text">→ {{ sig.recommendation }}{% if sig.doc_url %}<a href="{{ sig.doc_url }}" target="_blank" rel="noopener" class="doc-link">Learn more ↗</a>{% endif %}</p>{% endif %}
                </div>
                {% endfor %}
                {{ signin_breakdown(app) }}
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    <div class="pagination-bar" data-pagination="tbl-creds">
      <div><span class="pg-count" data-pg-count="tbl-creds"></span></div>
      <div style="display: flex; align-items: center; gap: 12px;">
