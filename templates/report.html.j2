            <option value="50">50</option>
            <option value="100">100</option>
            <option value="0">All</option>
          </select>
        </label>
        <div class="pagination-pages" data-pg-pages="tbl-creds"></div>
      </div>
    </div>
  </div>
  {% endif %}

