<script>
// ── Expandable rows ──────────────────────────────────────────────────────────
function toggleRow(id, trigger) {
  const row = document.getElementById(id);
  if (!row) return;
  const isOpen = row.classList.contains('open');
  row.classList.toggle('open', !isOpen);
  trigger.classList.toggle('open', !isOpen);
}

// ── Expand all / collapse all ────────────────────────────────────────────────
function toggleExpandAll(tableId, btn) {
  var table = document.getElementById(tableId);
  if (!table) return;
  var triggers = table.querySelectorAll('tbody tr.expand-trigger');
  var expandRows = table.querySelectorAll('tbody tr.expand-row');
  var anyOpen = Array.from(expandRows).some(function(r) { return r.classList.contains('open'); });

  if (anyOpen) {
    // Collapse all
    triggers.forEach(function(t) { t.classList.remove('open'); });
    expandRows.forEach(function(r) { r.classList.remove('open'); });
    btn.textContent = 'Expand All';
  } else {
    // Expand all
    triggers.forEach(function(t) { t.classList.add('open'); });
    expandRows.forEach(function(r) { r.classList.add('open'); });
    btn.textContent = 'Collapse All';
  }
}

// ── Copy app ID to clipboard ─────────────────────────────────────────────────
function copyAppId(btn, appId) {
  navigator.clipboard.writeText(appId).then(function() {
    btn.classList.add('copied');
    btn.innerHTML = '&#10003;';
    setTimeout(function() { btn.classList.remove('copied'); btn.innerHTML = '&#9112;'; }, 1500);
  });
}

// ── Review status tracking (localStorage) ────────────────────────────────────
var _reviewKey = 'ezapp-review-' + (document.title || 'report');

function getReviewStore() {
  try { return JSON.parse(localStorage.getItem(_reviewKey)) || {}; } catch(e) { return {}; }
}

function saveReviewStore(store) {
  try { localStorage.setItem(_reviewKey, JSON.stringify(store)); } catch(e) {}
}

var _statusCycle = ['unreviewed', 'reviewed', 'flagged', 'remediated'];
var _statusIcons = { unreviewed: '\u25CB', reviewed: '\u2713', flagged: '\u2691', remediated: '\u2714' };
var _statusTitles = { unreviewed: 'Not reviewed', reviewed: 'Reviewed', flagged: 'Needs attention', remediated: 'Remediated' };

function cycleReviewStatus(btn) {
  var appId = btn.dataset.appid;
  var current = btn.dataset.status;
  var idx = _statusCycle.indexOf(current);
  var next = _statusCycle[(idx + 1) % _statusCycle.length];
  btn.dataset.status = next;
  btn.innerHTML = _statusIcons[next];
  btn.title = _statusTitles[next];
  var store = getReviewStore();
  if (next === 'unreviewed') { delete store[appId]; } else { store[appId] = next; }
  saveReviewStore(store);
  updateAllProgressBars();
}

function restoreReviewStatuses() {
  var store = getReviewStore();
  document.querySelectorAll('.review-status').forEach(function(btn) {
    var status = store[btn.dataset.appid];
    if (status && _statusCycle.indexOf(status) > 0) {
      btn.dataset.status = status;
      btn.innerHTML = _statusIcons[status];
      btn.title = _statusTitles[status];
    }
  });
}

function updateAllProgressBars() {
  ['tbl-critical', 'tbl-stale', 'tbl-creds', 'tbl-orphaned', 'tbl-priv', 'tbl-owners'].forEach(function(tableId) {
    var bar = document.querySelector('[data-progress="' + tableId + '"]');
    if (!bar) return;
    var btns = document.querySelectorAll('#' + tableId + ' .review-status');
    var total = btns.length;
    var reviewed = 0;
    btns.forEach(function(b) { if (b.dataset.status !== 'unreviewed') reviewed++; });
    var pct = total > 0 ? Math.round(reviewed / total * 100) : 0;
    bar.querySelector('.progress-fill').style.width = pct + '%';
    bar.querySelector('.progress-text').textContent = reviewed + ' of ' + total + ' reviewed';
  });
}

// ── Sub-section table search/filter ──────────────────────────────────────────
var _subFilterState = {};

function filterSubTable(tableId, query) {
  query = (query || '').toLowerCase();
  _subFilterState[tableId] = query;
  var rows = document.querySelectorAll('#' + tableId + ' tbody tr');
  var visible = 0;
  var total = 0;

  rows.forEach(function(row) {
    if (row.classList.contains('expand-row')) return;
    total++;
    var name = row.dataset.name || '';
    var appid = row.dataset.appid || '';
    var match = !query || name.includes(query) || appid.includes(query);
    row.dataset._subFiltered = match ? '0' : '1';
    if (!match) {
      row.style.display = 'none';
      var next = row.nextElementSibling;
      if (next && next.classList.contains('expand-row')) { next.style.display = 'none'; next.classList.remove('open'); }
      row.classList.remove('open');
    }
    if (match) visible++;
  });

  var counter = document.querySelector('[data-sub-count="' + tableId + '"]');
  if (counter) {
    counter.textContent = query ? visible + ' of ' + total + ' matching' : '';
  }

  // Re-apply pagination with filtered rows
  if (_subPageState[tableId]) {
    _subPageState[tableId].currentPage = 1;
    applySubPaginationFiltered(tableId);
  }
}

// ── Export all rows in a section to CSV ──────────────────────────────────────
function exportAllTableCSV(tableId) {
  var rows = document.querySelectorAll('#' + tableId + ' tbody tr:not(.expand-row)');
  if (rows.length === 0) return;
  var data = [];
  rows.forEach(function(row) {
    data.push({
      app_name: row.querySelector('.app-name') ? row.querySelector('.app-name').textContent.replace(/[↗✓⚑✔○]/g,'').trim() : '',
      app_id: row.dataset.appid || '',
      risk_score: row.dataset.riskScore || '',
      risk_band: row.dataset.band || '',
      last_sign_in: row.dataset.lastSignin || '',
      days_since_sign_in: row.dataset.daysSince || '',
      owner_count: row.dataset.ownerCount || '',
      assignment_count: row.dataset.assignmentCount || '',
      account_enabled: row.dataset.accountEnabled || '',
      signal_keys: row.dataset.signalKeys || '',
      signal_count: row.dataset.signalCount || '',
      primary_recommendation: row.dataset.primaryRec || ''
    });
  });
  var csvLines = [_exportHeaders.join(',')];
  data.forEach(function(row) {
    csvLines.push(_exportHeaders.map(function(h) { return csvSafe(row[h]); }).join(','));
  });
  var blob = new Blob([csvLines.join('\n')], { type: 'text/csv;charset=utf-8;' });
  downloadBlob(blob, 'enterprise_zapp_' + tableId.replace('tbl-','') + '_all.csv');
}

// ── Owner group expand/collapse ──────────────────────────────────────────────
function toggleOwnerGroup(el) {
  el.classList.toggle('open');
}

function filterOwnerGroups(query) {
  query = (query || '').toLowerCase();
  var groups = document.querySelectorAll('#owner-groups-container .owner-group');
  var visible = 0;
  groups.forEach(function(g) {
    var name = g.dataset.ownerName || '';
    var upn = g.dataset.ownerUpn || '';
    var apps = g.dataset.appNames || '';
    var match = !query || name.includes(query) || upn.includes(query) || apps.includes(query);
    g.style.display = match ? '' : 'none';
    if (match) visible++;
  });
  var counter = document.getElementById('owner-match-count');
  if (counter) {
    counter.textContent = query ? visible + ' of ' + groups.length + ' owners matching' : '';
  }
}

// ── Back to top button visibility ────────────────────────────────────────────
(function() {
  var btn = document.getElementById('back-to-top');
  if (!btn) return;
  window.addEventListener('scroll', function() {
    btn.classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });
})();

// ── Keyboard shortcuts ──────────────────────────────────────────────────────
(function() {
  var sectionMap = { '1': 'sec-summary', '2': 'sec-inventory', '3': 'sec-critical', '4': 'sec-stale', '5': 'sec-creds', '6': 'sec-orphaned', '7': 'sec-priv', '8': 'sec-ca', '9': 'sec-owners' };
  document.addEventListener('keydown', function(e) {
    // Ignore if typing in an input
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') return;
    var modal = document.getElementById('kbd-modal');

    if (e.key === 'Escape') { modal.classList.remove('open'); return; }
    if (e.key === '?') { modal.classList.toggle('open'); e.preventDefault(); return; }
    if (e.key === 't' || e.key === 'T') { window.scrollTo({top:0, behavior:'smooth'}); return; }

    var sec = sectionMap[e.key];
    if (sec) {
      var el = document.getElementById(sec);
      if (el) { el.scrollIntoView({ behavior: 'smooth' }); e.preventDefault(); }
    }
  });
})();

// ── Table sorting ────────────────────────────────────────────────────────────
const sortState = {};
function sortTable(tableId, colIndex) {
  const table = document.getElementById(tableId);
  const tbody = table.querySelector('tbody');
  const ths = table.querySelectorAll('thead th');
  const key = tableId + '-' + colIndex;
  const asc = sortState[key] !== true;
  sortState[key] = asc;

  ths.forEach((th, i) => { th.classList.remove('asc', 'desc'); });
  ths[colIndex].classList.add(asc ? 'asc' : 'desc');

  // Capture each data row paired with its expand row BEFORE any DOM moves
  const pairs = Array.from(tbody.querySelectorAll('tr:not(.expand-row)')).map(row => ({
    data: row,
    expand: row.nextElementSibling?.classList.contains('expand-row')
      ? row.nextElementSibling : null,
  }));

  pairs.sort((a, b) => {
    const aCell = a.data.cells[colIndex];
    const bCell = b.data.cells[colIndex];
    const aVal = aCell?.dataset?.val ?? aCell?.textContent?.trim() ?? '';
    const bVal = bCell?.dataset?.val ?? bCell?.textContent?.trim() ?? '';
    const aNum = parseFloat(aVal);
    const bNum = parseFloat(bVal);
    if (!isNaN(aNum) && !isNaN(bNum)) return asc ? aNum - bNum : bNum - aNum;
    return asc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
  });

  // Re-insert data rows and their expand rows together, keeping them paired
  pairs.forEach(({ data, expand }) => {
    tbody.appendChild(data);
    if (expand) tbody.appendChild(expand);
  });

  // Re-apply sub-section pagination after sort
  if (_subPageState[tableId]) {
    _subPageState[tableId].currentPage = 1;
    applySubPagination(tableId);
  }
}

// ── Inventory filter state ────────────────────────────────────────────────────
let _activeBand = '';
let _hideMicrosoft = false;

// ── Band filter buttons ───────────────────────────────────────────────────────
function setBandFilter(btn, band) {
  _activeBand = band;

  // Update button active classes
  document.querySelectorAll('#inv-band-filters .band-btn').forEach(function(b) {
    // Remove all active-* classes
    b.className = b.className.replace(/\bactive-\S+/g, '').trim();
  });

  if (band === '') {
    btn.classList.add('active-all');
  } else {
    btn.classList.add('active-' + band);
  }

  filterTable();
}

// ── Microsoft toggle ──────────────────────────────────────────────────────────
function toggleMicrosoft() {
  _hideMicrosoft = !_hideMicrosoft;
  var btn = document.getElementById('ms-toggle');
  filterTable();  // Apply filter first to know the hidden count

  if (_hideMicrosoft) {
    var hiddenCount = document.querySelectorAll('#tbl-inventory tbody tr[data-microsoft="true"]').length;
    btn.textContent = 'Show All (' + hiddenCount + ' Microsoft hidden)';
    btn.classList.add('hiding');
  } else {
    btn.textContent = 'Hide Microsoft Apps';
    btn.classList.remove('hiding');
  }

  // Scroll the inventory section into view so the sticky column header
  // doesn't clip the first visible row after rows are shown/hidden.
  var section = document.getElementById('sec-inventory');
  if (section) {
    var navH = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--nav-height')) || 49;
    var y = section.getBoundingClientRect().top + window.pageYOffset - navH - 4;
    window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
  }
}

// ── Inventory filter ─────────────────────────────────────────────────────────
function filterTable() {
  const search = document.getElementById('inv-search').value.toLowerCase();
  const rows   = document.querySelectorAll('#tbl-inventory tbody tr');
  let visible  = 0;

  rows.forEach(function(row) {
    // Expand rows follow their parent data row — skip independent evaluation.
    if (row.classList.contains('expand-row')) return;

    const name      = row.dataset.name      || '';
    const appid     = row.dataset.appid     || '';
    const rband     = row.dataset.band      || '';
    const isMsft    = row.dataset.microsoft === 'true';

    const matchSearch    = !search      || name.includes(search) || appid.includes(search);
    const matchBand      = !_activeBand || rband === _activeBand;
    const matchMicrosoft = !_hideMicrosoft || !isMsft;

    const show = matchSearch && matchBand && matchMicrosoft;
    row.style.display = show ? '' : 'none';

    // Co-hide the sibling expand row so an open expand row doesn't orphan.
    var next = row.nextElementSibling;
    if (next && next.classList.contains('expand-row') && !show) {
      next.style.display = 'none';
    } else if (next && next.classList.contains('expand-row') && show) {
      next.style.display = '';  // revert to CSS (.expand-row default: none)
    }

    if (show) visible++;
  });

  const counter = document.getElementById('inv-count');
  const total   = document.querySelectorAll('#tbl-inventory tbody tr:not(.expand-row)').length;
  counter.textContent = 'Showing ' + visible + ' of ' + total + ' apps';

  // Keep toggle button count in sync when other filters change while MS hidden
  if (_hideMicrosoft) {
    var msHiddenAndMatchOther = 0;
    rows.forEach(function(row) {
      if (row.dataset.microsoft === 'true') {
        const name   = row.dataset.name  || '';
        const appid  = row.dataset.appid || '';
        const rband  = row.dataset.band  || '';
        const matchS = !search      || name.includes(search) || appid.includes(search);
        const matchB = !_activeBand || rband === _activeBand;
        if (matchS && matchB) msHiddenAndMatchOther++;
      }
    });
    var btn = document.getElementById('ms-toggle');
    btn.textContent = 'Show All (' + msHiddenAndMatchOther + ' Microsoft hidden)';
  }
}

// Init counter — handled by pagination-aware filterTable() override below.

// ── Row selection & export (generic for all tables) ─────────────────────────
var _exportHeaders = [
  'app_name', 'app_id', 'risk_score', 'risk_band', 'last_sign_in',
  'days_since_sign_in', 'owner_count', 'assignment_count', 'account_enabled',
  'signal_keys', 'signal_count', 'primary_recommendation'
];

function getTableCheckboxes(tableId, visibleOnly) {
  var cbs = [];
  document.querySelectorAll('#' + tableId + ' tbody tr:not(.expand-row)').forEach(function(row) {
    if (visibleOnly && row.style.display === 'none') return;
    var cb = row.querySelector('.row-select-cb');
    if (cb) cbs.push(cb);
  });
  return cbs;
}

function updateTableSelectCount(tableId) {
  var allCbs = getTableCheckboxes(tableId, false);
  var checked = allCbs.filter(function(cb) { return cb.checked; }).length;

  // Update count label
  var counter = document.querySelector('[data-select-count="' + tableId + '"]');
  if (counter) counter.textContent = checked + ' selected';

  // Enable/disable export buttons
  document.querySelectorAll('[data-export-btn="' + tableId + '"]').forEach(function(btn) {
    btn.disabled = checked === 0;
  });

  // Sync the select-all checkbox in the thead
  var visibleCbs = getTableCheckboxes(tableId, true);
  var masterCb = document.querySelector('#' + tableId + ' thead .row-select-cb');
  if (masterCb) {
    var visChecked = visibleCbs.filter(function(cb) { return cb.checked; }).length;
    masterCb.checked = visibleCbs.length > 0 && visChecked === visibleCbs.length;
    masterCb.indeterminate = visChecked > 0 && visChecked < visibleCbs.length;
  }
}

// Inventory-specific wrappers (called by existing onchange/onclick in inventory table)
function updateSelectCount() { updateTableSelectCount('tbl-inventory'); }
function toggleSelectAll(masterCb) { toggleTableSelectAll(masterCb, 'tbl-inventory'); }
function exportSelectedCSV() { exportTableCSV('tbl-inventory'); }
function exportSelectedXLSX() { exportTableXLSX('tbl-inventory'); }

function toggleTableSelectAll(masterCb, tableId) {
  var cbs = getTableCheckboxes(tableId, true);
  cbs.forEach(function(cb) { cb.checked = masterCb.checked; });
  updateTableSelectCount(tableId);
}

function getSelectedTableRows(tableId) {
  var rows = [];
  document.querySelectorAll('#' + tableId + ' tbody tr:not(.expand-row)').forEach(function(row) {
    var cb = row.querySelector('.row-select-cb');
    if (cb && cb.checked) rows.push(row);
  });
  return rows;
}

function buildTableExportData(tableId) {
  var rows = getSelectedTableRows(tableId);
  var data = rows.map(function(row) {
    return {
      app_name:                row.querySelector('.app-name') ? row.querySelector('.app-name').textContent.replace(/↗/g,'').trim() : '',
      app_id:                  row.dataset.appid || '',
      risk_score:              row.dataset.riskScore || '',
      risk_band:               row.dataset.band || '',
      last_sign_in:            row.dataset.lastSignin || '',
      days_since_sign_in:      row.dataset.daysSince || '',
      owner_count:             row.dataset.ownerCount || '',
      assignment_count:        row.dataset.assignmentCount || '',
      account_enabled:         row.dataset.accountEnabled || '',
      signal_keys:             row.dataset.signalKeys || '',
      signal_count:            row.dataset.signalCount || '',
      primary_recommendation:  row.dataset.primaryRec || ''
    };
  });
  return { headers: _exportHeaders, data: data };
}

function csvSafe(val) {
  if (!val) return val;
  var s = String(val);
  if (s[0] === '=' || s[0] === '+' || s[0] === '-' || s[0] === '@' || s[0] === '\t' || s[0] === '\r') {
    s = "'" + s;
  }
  if (s.indexOf('"') !== -1 || s.indexOf(',') !== -1 || s.indexOf('\n') !== -1) {
    s = '"' + s.replace(/"/g, '""') + '"';
  }
  return s;
}

function exportTableCSV(tableId) {
  var exp = buildTableExportData(tableId);
  if (exp.data.length === 0) return;
  var csvLines = [exp.headers.join(',')];
  exp.data.forEach(function(row) {
    csvLines.push(exp.headers.map(function(h) { return csvSafe(row[h]); }).join(','));
  });
  var blob = new Blob([csvLines.join('\n')], { type: 'text/csv;charset=utf-8;' });
  downloadBlob(blob, 'enterprise_zapp_selected.csv');
}

function exportTableXLSX(tableId) {
  var exp = buildTableExportData(tableId);
  if (exp.data.length === 0) return;
  var xml = '<?xml version="1.0"?>\n';
  xml += '<?mso-application progid="Excel.Sheet"?>\n';
  xml += '<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"\n';
  xml += ' xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">\n';
  xml += '<Worksheet ss:Name="Selected Apps"><Table>\n';
  xml += '<Row>';
  exp.headers.forEach(function(h) {
    xml += '<Cell><Data ss:Type="String">' + escapeXml(h) + '</Data></Cell>';
  });
  xml += '</Row>\n';
  exp.data.forEach(function(row) {
    xml += '<Row>';
    exp.headers.forEach(function(h) {
      var val = row[h] || '';
      var type = isFinite(val) && val !== '' ? 'Number' : 'String';
      xml += '<Cell><Data ss:Type="' + type + '">' + escapeXml(val) + '</Data></Cell>';
    });
    xml += '</Row>\n';
  });
  xml += '</Table></Worksheet></Workbook>';
  var blob = new Blob([xml], { type: 'application/vnd.ms-excel' });
  downloadBlob(blob, 'enterprise_zapp_selected.xlsx');
}

function escapeXml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function downloadBlob(blob, filename) {
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(a.href);
}

// ── Generic pagination for sub-section tables ───────────────────────────────
var _subPageState = {};

function getSubDataRows(tableId) {
  return Array.from(document.querySelectorAll('#' + tableId + ' tbody tr:not(.expand-row)')).filter(function(row) {
    return row.dataset._subFiltered !== '1';
  });
}

function applySubPaginationFiltered(tableId) {
  // Hide all rows first, then let pagination show the right ones
  document.querySelectorAll('#' + tableId + ' tbody tr:not(.expand-row)').forEach(function(row) {
    if (row.dataset._subFiltered === '1') {
      row.style.display = 'none';
    }
  });
  applySubPagination(tableId);
}

function applySubPagination(tableId) {
  var state = _subPageState[tableId];
  if (!state) return;
  var rows = getSubDataRows(tableId);
  var total = rows.length;
  var ps = state.pageSize;
  var totalPages = ps > 0 ? Math.max(1, Math.ceil(total / ps)) : 1;
  if (state.currentPage > totalPages) state.currentPage = totalPages;

  rows.forEach(function(row, i) {
    var inPage = ps === 0 || (i >= (state.currentPage - 1) * ps && i < state.currentPage * ps);
    row.style.display = inPage ? '' : 'none';
    var next = row.nextElementSibling;
    if (next && next.classList.contains('expand-row')) {
      if (!inPage) {
        next.style.display = 'none';
        next.classList.remove('open');
        row.classList.remove('open');
      } else {
        next.style.display = '';
      }
    }
  });

  // Update counter
  var startIdx = ps > 0 ? (state.currentPage - 1) * ps + 1 : 1;
  var endIdx = ps > 0 ? Math.min(state.currentPage * ps, total) : total;
  var counter = document.querySelector('[data-pg-count="' + tableId + '"]');
  if (counter) {
    if (total === 0) {
      counter.textContent = 'No apps';
    } else if (ps === 0) {
      counter.textContent = 'Showing all ' + total + ' apps';
    } else {
      counter.textContent = 'Showing ' + startIdx + '\u2013' + endIdx + ' of ' + total + ' apps';
    }
  }

  // Render page buttons
  var pagesDiv = document.querySelector('[data-pg-pages="' + tableId + '"]');
  if (!pagesDiv) return;
  pagesDiv.innerHTML = '';
  if (ps > 0 && totalPages > 1) {
    var prevBtn = document.createElement('button');
    prevBtn.textContent = '\u2039';
    prevBtn.disabled = state.currentPage === 1;
    prevBtn.onclick = function() { state.currentPage--; applySubPagination(tableId); };
    pagesDiv.appendChild(prevBtn);

    var pages = [];
    if (totalPages <= 7) {
      for (var i = 1; i <= totalPages; i++) pages.push(i);
    } else {
      pages.push(1);
      if (state.currentPage > 3) pages.push('...');
      for (var i = Math.max(2, state.currentPage - 1); i <= Math.min(totalPages - 1, state.currentPage + 1); i++) pages.push(i);
      if (state.currentPage < totalPages - 2) pages.push('...');
      pages.push(totalPages);
    }
    pages.forEach(function(p) {
      if (p === '...') {
        var span = document.createElement('span');
        span.textContent = '...';
        span.style.padding = '0 4px';
        pagesDiv.appendChild(span);
      } else {
        var btn = document.createElement('button');
        btn.textContent = p;
        if (p === state.currentPage) btn.classList.add('active');
        btn.onclick = (function(page) { return function() { state.currentPage = page; applySubPagination(tableId); }; })(p);
        pagesDiv.appendChild(btn);
      }
    });

    var nextBtn = document.createElement('button');
    nextBtn.textContent = '\u203A';
    nextBtn.disabled = state.currentPage === totalPages;
    nextBtn.onclick = function() { state.currentPage++; applySubPagination(tableId); };
    pagesDiv.appendChild(nextBtn);
  }
}

function changeSubPageSize(tableId, val) {
  if (!_subPageState[tableId]) _subPageState[tableId] = { pageSize: 25, currentPage: 1 };
  _subPageState[tableId].pageSize = parseInt(val, 10);
  _subPageState[tableId].currentPage = 1;
  applySubPagination(tableId);
}

// Initialize pagination for all sub-section tables
['tbl-critical', 'tbl-stale', 'tbl-creds', 'tbl-orphaned', 'tbl-priv'].forEach(function(tableId) {
  if (document.getElementById(tableId)) {
    _subPageState[tableId] = { pageSize: 25, currentPage: 1 };
    applySubPagination(tableId);
  }
});

// Restore review statuses from localStorage and update progress bars
restoreReviewStatuses();
updateAllProgressBars();

// ── Pagination for inventory table ───────────────────────────────────────────
var _pageSize = 25;
var _currentPage = 1;

function getVisibleDataRows() {
  var rows = [];
  document.querySelectorAll('#tbl-inventory tbody tr:not(.expand-row)').forEach(function(row) {
    if (row.dataset._filteredOut !== '1') rows.push(row);
  });
  return rows;
}

function applyPagination() {
  var visibleRows = getVisibleDataRows();
  var total = visibleRows.length;
  var totalPages = _pageSize > 0 ? Math.max(1, Math.ceil(total / _pageSize)) : 1;
  if (_currentPage > totalPages) _currentPage = totalPages;

  visibleRows.forEach(function(row, i) {
    var inPage = _pageSize === 0 || (i >= (_currentPage - 1) * _pageSize && i < _currentPage * _pageSize);
    row.style.display = inPage ? '' : 'none';
    var next = row.nextElementSibling;
    if (next && next.classList.contains('expand-row')) {
      if (!inPage) {
        next.style.display = 'none';
      } else {
        next.style.display = '';  // revert to CSS default
      }
    }
  });

  // Update counter
  var startIdx = _pageSize > 0 ? (_currentPage - 1) * _pageSize + 1 : 1;
  var endIdx = _pageSize > 0 ? Math.min(_currentPage * _pageSize, total) : total;
  var allTotal = document.querySelectorAll('#tbl-inventory tbody tr:not(.expand-row)').length;
  var counter = document.getElementById('inv-count');
  if (total === 0) {
    counter.textContent = 'No apps match filters';
  } else if (total === allTotal && _pageSize === 0) {
    counter.textContent = 'Showing all ' + total + ' apps';
  } else if (_pageSize === 0) {
    counter.textContent = 'Showing all ' + total + ' of ' + allTotal + ' apps';
  } else {
    counter.textContent = 'Showing ' + startIdx + '–' + endIdx + ' of ' + total + ' apps' + (total < allTotal ? ' (' + allTotal + ' total)' : '');
  }

  // Render page buttons
  var pagesDiv = document.getElementById('inv-pages');
  pagesDiv.innerHTML = '';
  if (_pageSize > 0 && totalPages > 1) {
    var prevBtn = document.createElement('button');
    prevBtn.textContent = '\u2039';
    prevBtn.disabled = _currentPage === 1;
    prevBtn.onclick = function() { goToPage(_currentPage - 1); };
    pagesDiv.appendChild(prevBtn);

    // Show smart page range
    var pages = [];
    if (totalPages <= 7) {
      for (var i = 1; i <= totalPages; i++) pages.push(i);
    } else {
      pages.push(1);
      if (_currentPage > 3) pages.push('...');
      for (var i = Math.max(2, _currentPage - 1); i <= Math.min(totalPages - 1, _currentPage + 1); i++) pages.push(i);
      if (_currentPage < totalPages - 2) pages.push('...');
      pages.push(totalPages);
    }
    pages.forEach(function(p) {
      if (p === '...') {
        var span = document.createElement('span');
        span.textContent = '...';
        span.style.padding = '0 4px';
        pagesDiv.appendChild(span);
      } else {
        var btn = document.createElement('button');
        btn.textContent = p;
        if (p === _currentPage) btn.classList.add('active');
        btn.onclick = (function(page) { return function() { goToPage(page); }; })(p);
        pagesDiv.appendChild(btn);
      }
    });

    var nextBtn = document.createElement('button');
    nextBtn.textContent = '\u203A';
    nextBtn.disabled = _currentPage === totalPages;
    nextBtn.onclick = function() { goToPage(_currentPage + 1); };
    pagesDiv.appendChild(nextBtn);
  }
}

function goToPage(page) {
  _currentPage = page;
  applyPagination();
}

function changePageSize(val) {
  _pageSize = parseInt(val, 10);
  _currentPage = 1;
  applyPagination();
}

// Override filterTable to integrate with pagination
var _origFilterTable = filterTable;
filterTable = function() {
  var search = document.getElementById('inv-search').value.toLowerCase();
  var rows = document.querySelectorAll('#tbl-inventory tbody tr');

  rows.forEach(function(row) {
    if (row.classList.contains('expand-row')) return;

    var name      = row.dataset.name      || '';
    var appid     = row.dataset.appid     || '';
    var rband     = row.dataset.band      || '';
    var isMsft    = row.dataset.microsoft === 'true';

    var matchSearch    = !search      || name.includes(search) || appid.includes(search);
    var matchBand      = !_activeBand || rband === _activeBand;
    var matchMicrosoft = !_hideMicrosoft || !isMsft;

    var show = matchSearch && matchBand && matchMicrosoft;
    row.dataset._filteredOut = show ? '0' : '1';
    if (!show) {
      row.style.display = 'none';
      var next = row.nextElementSibling;
      if (next && next.classList.contains('expand-row')) next.style.display = 'none';
    }
  });

  // Keep toggle button count in sync
  if (_hideMicrosoft) {
    var msHiddenAndMatchOther = 0;
    rows.forEach(function(row) {
      if (row.classList.contains('expand-row')) return;
      if (row.dataset.microsoft === 'true') {
        var name   = row.dataset.name  || '';
        var appid  = row.dataset.appid || '';
        var rband  = row.dataset.band  || '';
        var matchS = !search      || name.includes(search) || appid.includes(search);
        var matchB = !_activeBand || rband === _activeBand;
        if (matchS && matchB) msHiddenAndMatchOther++;
      }
    });
    var btn = document.getElementById('ms-toggle');
    btn.textContent = 'Show All (' + msHiddenAndMatchOther + ' Microsoft hidden)';
  }

  _currentPage = 1;
  applyPagination();
};

// Re-run with pagination
filterTable();

// ── Dynamic nav height (used for section scroll-margin-top) ──────────────────
// Tables no longer rely on --nav-height for their sticky headers — they use
// overflow-y scroll containers with top:0. This variable only drives the
// scroll-margin-top on .section elements so nav anchor links land correctly.
(function() {
  function updateNavHeight() {
    var nav = document.getElementById('sticky-nav');
    if (nav) {
      document.documentElement.style.setProperty('--nav-height', nav.offsetHeight + 'px');
    }
  }
  updateNavHeight();
  window.addEventListener('resize', updateNavHeight, { passive: true });
  window.addEventListener('load', updateNavHeight, { passive: true });
})();

// ── Scroll spy for sticky nav ─────────────────────────────────────────────────
(function() {
  var sections = document.querySelectorAll('.section[id]');
  var navLinks = document.querySelectorAll('.sticky-nav a');
  var OFFSET = 80;
  function onScroll() {
    var current = '';
    sections.forEach(function(sec) {
      if (sec.getBoundingClientRect().top <= OFFSET) current = sec.id;
    });
    navLinks.forEach(function(a) {
      a.classList.toggle('active', a.getAttribute('href') === '#' + current);
    });
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
})();
</script>
</body>
</html>
